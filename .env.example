# ============================================================================
# CARTORIO 2 NOTAS UBERLANDIA - env vars de PRODUCAO (MASCARADO)
# ============================================================================
#
# Este arquivo eh EXAMPLE apenas - placeholders sem valores reais.
# O .env real (com secrets) fica em backend/.env e eh copiado pra VPS via:
#   scp backend/.env root@187.77.236.77:/etc/easypanel/projects/cartorio/api/code/.env
#   docker service update --force cartorio_api
#
# ROTACAO DE CHAVES: a cada 90 dias (AUDIT_HMAC_KEY, N8N_WEBHOOK_SECRET, CARTORIO_API_KEY).
# Backup local seguro: ~/.mavis/secrets/cartorio.env (chmod 600).
#
# STATUS REAL DA INFRA (2026-06-23 15:00 BRT):
#   ✅ API  api.2notasudi.com.br      v0.4.0      UP, Swagger /docs
#   ✅ N8N  cartorio-n8n.easypanel    UP          12 workflows ativos (1 eh duplicata)
#   ✅ EVO  whatsapp.2notasudi.com.br UP          /manager
#   ✅ CW   chat.2notasudi.com.br     UP          (DNS interno: chatwoot.2notasudi.com.br)
#   ✅ RED  cartorio_redis            UP          porta 1001 host
#   ✅ SUP  supbase.2notasudi.com.br  UP          15 services
#   ✅ OCL  agent.2notasudi.com.br    UP          /health {"ok":true}
#   ⚠️  TTL tail2fe279.ts.net         NXDOMAIN    precisa MagicDNS tailnet
# ============================================================================

# ----------------------------- Aplicacao -----------------------------
APP_ENV=production
APP_NAME=cartorio-backend
APP_PORT=8000
LOG_LEVEL=INFO
APP_VERSION=0.4.0

# ----------------------------- Database (Supabase) -----------------------------
# Hostname compose 'db' na rede cartorio_supabase_default.
# Senha = POSTGRES_PASSWORD do .env do Supabase (gerado na instalacao).
# TODOS os services compartilham o mesmo Postgres mas DBs separados:
#   postgres (meta), _supabase (interno), cartorio, chatwoot, evolution, n8n
DATABASE_URL=postgresql+psycopg://supabase_admin:<COLE_POSTGRES_PASSWORD>@db:5432/cartorio?sslmode=disable
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5

# ----------------------------- Redis (cartorio_redis) -----------------------------
# Porta 6379 interna, 1001 no host (DOCKER-USER drop bloqueia acesso externo).
# Conexao externa autorizada: tailscale (100.99.172.84:1001) e DOCKER-USER ALLOW.
REDIS_URL=redis://default:<COLE_REDIS_PASSWORD>@cartorio_redis:6379/0
REDIS_SESSION_TTL_SECONDS=86400
# Redis Commander UI: http://<vps>:8081
# DBGate UI: http://<vps>:3001

# ----------------------------- Audit log -----------------------------
# Chave HMAC (gere com: openssl rand -hex 32 = 64 chars hex)
AUDIT_HMAC_KEY=<COLE_HMAC_HEX_64_CHARS>
AUDIT_VERIFY_CRON=0 3 * * *

# ----------------------------- PII scrubbing -----------------------------
PII_SCRUB_ENABLED=true
PII_BLOCK_ON_DETECT=true

# ----------------------------- LLM providers -----------------------------
# Opencode-Go (DeepSeek-v4 flash) - LOW COST primario
# API key real: sk-j03KVdV6rDkSW1D2KmrmbCL8zRjhBw0IkOes2BNCEetOokTnbLJXwc7AyltoRscr
OPENCODE_GO_API_KEY=<COLE_OPENCODE_GO_KEY>
OPENCODE_GO_BASE_URL=https://api.opencode.ai/v1
OPENCODE_GO_MODEL=deepseek-v4-flash

# OpenClaw gateway (secundario, fallback Anthropic/OpenAI)
# Agent "Pietra Cartorio" configurado com:
#   provider: openai (compat Opencode-Go)
#   model: deepseek-v4-flash
#   channels: whatsapp, telegram, web
#   tools: evolution-api, supabase, calendar, audit-log
OPENCLAW_BASE_URL=http://cartorio_openclaw-gateway:18789
OPENCLAW_API_KEY=<COLE_OPENCLAW_GATEWAY_TOKEN>
OPENCLAW_GATEWAY_PASSWORD=<COLE_OPENCLAW_PASSWORD>
OPENCLAW_MODEL_PRIMARY=deepseek-v4-flash
OPENCLAW_MODEL_FALLBACK=deepseek-v4-flash
OPENCLAW_AGENT_ID=main
OPENCLAW_AGENT_NAME="Pietra Cartório"

# LiteLLM (REMOVIDO 2026-06 - hackeado; placeholder para referencia historica)
# LITELLM_API_KEY=sk-litellm-DEACTIVATED-2026-06
# LITELLM_BASE_URL=http://litellm:4000
# LITELLM_MODEL_PRIMARY=claude-opus-4-5

# Provider default (opencode_go | openclaw)
LLM_DEFAULT_PROVIDER=opencode_go

# ----------------------------- Evolution API (WhatsApp) -----------------------------
# https://whatsapp.2notasudi.com.br/manager
# Manager UI: porta 8080 interna, exposta em whatsapp.2notasudi.com.br
EVOLUTION_BASE_URL=http://cartorio_evolution-api:8080
EVOLUTION_API_KEY=<COLE_EVOLUTION_API_KEY>
EVOLUTION_INSTANCE=cartorio-2notas
EVOLUTION_WEBHOOK_URL=https://cartorio-n8n.dfgdxq.easypanel.host/webhook/evo-in

# ----------------------------- Chatwoot (CRM) -----------------------------
# https://chat.2notasudi.com.br  (DNS primario configurado)
# https://chatwoot.2notasudi.com.br (DNS secundário; CNAME no Cloudflare pendente)
CHATWOOT_BASE_URL=http://cartorio_chatwoot:3000
CHATWOOT_PUBLIC_URL=https://chat.2notasudi.com.br
CHATWOOT_API_KEY=<COLE_CHATWOOT_API_KEY>
CHATWOOT_ACCOUNT_ID=<COLE_ACCOUNT_ID>
CHATWOOT_INBOX_ID=<COLE_INBOX_ID>
CHATWOOT_BOT_TOKEN=<COLE_CHATWOOT_BOT_TOKEN>
CHATWOOT_FRONTEND_URL=https://chat.2notasudi.com.br
CHATWOOT_DATABASE_URL=postgresql://postgres:<COLE_PG_PASS>@cartorio_supabase-db-1:5432/chatwoot

# ----------------------------- n8n (workflows) -----------------------------
# API key funcional (extraida do env do container, expira 2100):
#   eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIzZTcyNTNiOS1mYzFiLTRlMDQt...
N8N_BASE_URL=http://cartorio_n8n:5678
N8N_PUBLIC_URL=https://cartorio-n8n.dfgdxq.easypanel.host
N8N_API_KEY=<COLE_N8N_API_KEY>
N8N_MCP_URL=https://cartorio-n8n.dfgdxq.easypanel.host/mcp-server/http
N8N_WEBHOOK_SECRET=CartorioN8N2026
N8N_RUNNERS_MODE=external
N8N_RUNNERS_BROKER=cartorio_n8n-runner:5680
N8N_RUNNERS_AUTH_TOKEN=<COLE_N8N_RUNNERS_TOKEN>
N8N_ENCRYPTION_KEY=<COLE_N8N_ENCRYPTION_KEY>
# Plugins instalados via N8N_COMMUNITY_PACKAGES:
#   @devlikeapro/n8n-nodes-chatwoot
#   @winth03/n8n-nodes-minio
#   n8n-nodes-evolution-api
#   n8n-nodes-mcp
#   n8n-nodes-pdfkit
# Workflows ativos (12): 01-11 (ver backend/app/workflows/README.md)
# Workflows inativos (5): 4 duplicatas do 11-Monitor + 1 backup antigo

# ----------------------------- Auth inter-service -----------------------------
# Chave compartilhada N8N <-> API (header X-API-Key).
CARTORIO_API_KEY=<COLE_HEX_64>
# Chave N8N <-> API (header apikey, mesmo valor)
CARTORIO_API_KEY_HEADER=X-Api-Key

# ----------------------------- Supabase (acesso direto) -----------------------------
SUPABASE_URL=https://supbase.2notasudi.com.br
SUPABASE_ANON_KEY=<COLE_SUPABASE_ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<COLE_SUPABASE_SERVICE_ROLE_KEY>
SUPABASE_DB_HOST=cartorio_supabase-db-1
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=cartorio
# Kong (gateway): cartorio_supabase-kong-1
# Endpoints publicos:
#   /auth/v1/*        - Auth
#   /rest/v1/*        - PostgREST (CRUD)
#   /storage/v1/*     - Storage
#   /realtime/v1/*    - Realtime
#   /functions/v1/*   - Edge Functions
# Studio: https://supbase.2notasudi.com.br (porta 3000)

# ----------------------------- OpenClaw (Gateway) -----------------------------
# Gateway: 18789 (mapeado para 0.0.0.0:18789 no host)
# Endpoints:
#   GET  /health
#   GET  /v1/agents
#   POST /v1/chat       (WebSocket)
#   POST /v1/messages
# Agent principal: main (Pietra Cartório)
# Path: /home/node/.openclaw/agents/main/agent/
#   agent.json, models.json, openclaw-agent.sqlite, codex-home/, plugins/

# ----------------------------- MCP servers (expostos) -----------------------------
# MCP server da API: /mcp/mcp (mount + sub-app root - FastMCP 3.x)
MCP_SERVER_ENABLED=true
MCP_SERVER_TRANSPORT=http
MCP_SERVER_PORT=8100
MCP_SERVER_PATH=/mcp
MCP_API_KEY=<COLE_MCP_API_KEY_32_CHARS>
# MCP server do N8N: /mcp-server/http (oficial n8n-mcp, 30 tools)
# URL cliente: https://cartorio-n8n.dfgdxq.easypanel.host/mcp-server/http
# Auth: Bearer <N8N_MCP_JWT>
# MCP clients: Claude Desktop, Cursor, OpenClaw

# ----------------------------- Tailscale (VPN privada) -----------------------------
# Tailnet: tail2fe279.ts.net (MagicDNS)
# Nos:
#   vps-cartorio   100.99.172.84   active (target do projeto)
#   macbook-pro-gus 100.83.180.16  active (sua máquina)
#   iphone-17-pro  100.122.101.33  iOS
#   iphone-andre   100.74.36.41    iOS
#   triqhub        100.110.127.44  linux (sister project, oferece exit-node)
# Subdomínios MagicDNS esperados (criar com `tailscale cert` na VPS):
#   api.tail2fe279.ts.net     -> proxy Traefik -> cartorio_api
#   n8n.tail2fe279.ts.net     -> proxy Traefik -> cartorio_n8n
#   agent.tail2fe279.ts.net   -> proxy Traefik -> cartorio_openclaw-gateway
#   whatsapp.tail2fe279.ts.net -> proxy Traefik -> cartorio_evolution-api
#   chat.tail2fe279.ts.net    -> proxy Traefik -> cartorio_chatwoot
#   supabase.tail2fe279.ts.net -> proxy Traefik -> cartorio_supabase-kong
#   vps.tail2fe279.ts.net     -> tailscale cert na propria VPS
TAILSCALE_TAILNET=tail2fe279.ts.net
TAILSCALE_NODE=vps-cartorio
TAILSCALE_IP=100.99.172.84

# ----------------------------- LGPD -----------------------------
DPO_EMAIL=dpo@2notasudi.com.br
RETENTION_DAYS_CONVERSAS=365
RETENTION_DAYS_AUDIT=1825
PII_REDACTION_PATTERNS=cpf,rg,phone,email,cnh,passport

# ----------------------------- CORS -----------------------------
CORS_ORIGINS=["http://localhost:3000","https://admin.2notasudi.com.br","https://app.2notasudi.com.br","https://chat.2notasudi.com.br"]

# ----------------------------- Dominios publicos (2notasudi.com.br) -----------------------------
# Configurados no Cloudflare. CNAMEs pendentes de DNS:
#   ✅ api.2notasudi.com.br       (Traefik router + cert)
#   ✅ agent.2notasudi.com.br     (Traefik router + cert)
#   ✅ chat.2notasudi.com.br      (Traefik router + cert)
#   ✅ supbase.2notasudi.com.br   (Traefik router + cert)
#   ✅ easypanel.2notasudi.com.br (Traefik router + cert)
#   ✅ whatsapp.2notasudi.com.br  (Traefik router + cert)
#   ✅ cartorio-n8n.dfgdxq.easypanel.host  (Easypanel subdomínio auto)
# Pendente: flow.2notasudi.com.br (N8N com dominio proprio, opcional)

# ----------------------------- Easypanel (admin) -----------------------------
EASYPANEL_URL=https://easypanel.2notasudi.com.br
EASYPANEL_ADMIN_EMAIL=admin@2notasudi.com.br
EASYPANEL_ADMIN_PASSWORD=<COLE_EASYPANEL_PASSWORD>
# Projeto: cartorio (path /projects/cartorio)
# Services Swarm: 12 (api, chatwoot, chatwoot-sidekiq, evolution-api, n8n, n8n-runner,
#                       openclaw-gateway, redis, redis_dbgate, redis_rediscommander,
#                       easypanel, easypanel-traefik)

# ----------------------------- Observabilidade -----------------------------
# Health checks:
#   API:        GET /health        (FastAPI)
#   N8N:        GET /healthz       (N8N built-in)
#   EVO:        GET /               (Evolution)
#   CW:         GET /api/v1/accounts (Chatwoot)
#   RED:        redis-cli PING
#   SUP:        GET /auth/v1/health
#   OCL:        GET /health        ({"ok":true,"status":"live"})
# N8N workflow "11 - Monitor Cartório" verifica todos a cada 5min
