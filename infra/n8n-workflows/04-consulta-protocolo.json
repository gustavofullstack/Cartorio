          {
            "node": "Handoff Humano",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "GET /protocolo/{id}": {
      "main": [
        [
          {
            "node": "Respond OK",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
