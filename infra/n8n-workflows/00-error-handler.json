    {
      "parameters": {
        "method": "POST",
        "url": "https://api.2notasudi.com.br/api/v1/integrations/n8n/error",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "X-N8N-Signature",
              "value": "sha256={{ $binary.data ? Crypto.createHmac('sha256', $env.N8N_WEBHOOK_SECRET).update($binary.data).digest('hex') : '' }}"
            },
            {
              "name": "X-Correlation-ID",
              "value": "={{ $json.correlation_id }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"workflow_name\": \"{{ $json.wf_name }}\",\n  \"workflow_id\": \"{{ $json.wf_id }}\",\n  \"execution_id\": \"{{ $json.execution_id }}\",\n  \"error\": {\n    \"name\": \"{{ $json.error_name }}\",\n    \"message\": \"{{ $json.error_message }}\"\n  },\n  \"node\": \"{{ $json.node_name }}\",\n  \"timestamp\": \"{{ $json.ts }}\"\n}",
        "options": {
          "timeout": 5000,
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "alert-backend-5",
      "name": "Alert Backend (HMAC)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        680,
        300
      ],
      "options": {
        "timeout": 5000
      }
