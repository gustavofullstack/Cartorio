  "id": "MzeYTSDouymzdpRw",
  "name": "02 - Criar Protocolo (LGPD)",
  "description": null,
  "active": true,
  "isArchived": false,
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "criar-protocolo",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook WhatsApp",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        240,
        300
      ],
      "webhookId": "criar-protocolo-v1"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// PII scrub + LGPD consentimento check\nconst item = $input.item.json;\nconst body = item.body || {};\nconst sender = body.sender || 'unknown';\nconst text = (body.message && body.message.text) || '';\nconst consentimento_lgpd = body.consentimento_lgpd === true;\n\nconst patterns = {\n  cpf: /\\b\\d{3}\\.?\\d{3}\\.?\\d{3}-?\\d{2}\\b/g,\n  rg: /\\b\\d{1,2}\\.?\\d{3}\\.?\\d{3}-?\\d{1}\\b/g,\n  phone: /\\b\\(\\d{2}\\)\\s?9?\\d{4}-?\\d{4}\\b/g,\n  email: /\\b[\\w.-]+@[\\w.-]+\\.\\w+\\b/g\n};\n\nlet scrubbed = text;\nlet findings = [];\nlet redactionCount = 0;\n\nfor (const [type, pattern] of Object.entries(patterns)) {\n  const matches = scrubbed.match(pattern);\n  if (matches) {\n    findings.push({ type, count: matches.length });\n    redactionCount += matches.length;\n    scrubbed = scrubbed.replace(pattern, `[${type.toUpperCase()}_REDACTED]`);\n  }\n}\n\n// LGPD gate: consentimento explicito obrigatorio para criar protocolo\nconst lgpd_blocked = !consentimento_lgpd;\n\n// Extrair tipo de ato do texto\nconst lower = scrubbed.toLowerCase();\nlet tipo_ato = 'certidao_casamento';\nif (/escritur/.test(lower)) tipo_ato = 'escritura';\nelse if (/procur/.test(lower)) tipo_ato = 'procuracao';\n\nreturn { json: {\n  sender,\n  raw: text,\n  scrubbed,\n  findings,\n  redactionCount,\n  consentimento_lgpd,\n  lgpd_blocked,\n  tipo_ato,\n  instance: body.instance || 'unknown'\n}};"
      },
      "id": "pii-scrub",
      "name": "PII Scrub + LGPD Check",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "lgpd-blocked",
              "leftValue": "={{ $json.lgpd_blocked }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-lgpd",
      "name": "LGPD bloqueado?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        680,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.2notasudi.com.br/api/v1/protocolo",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "X-Request-Source",
              "value": "n8n-workflow-02"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"sender\": \"{{ $json.sender }}\",\n  \"tipo_ato\": \"{{ $json.tipo_ato }}\",\n  \"descricao\": \"{{ $json.scrubbed }}\",\n  \"consentimento_lgpd\": {{ $json.consentimento_lgpd }},\n  \"instance\": \"{{ $json.instance }}\",\n  \"pii_scrubbed\": true\n}",
        "options": {
          "timeout": 15000,
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "api-protocolo",
      "name": "POST /protocolo",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        900,
        200
      ],
      "onError": "continueRegularOutput",
      "retryOnFail": false,
      "options": {
        "timeout": 5000
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"status\": \"created\",\n  \"protocolo\": \"CART-{{ new Date().getFullYear() }}-{{ Math.floor(Math.random()*1000000) }}\",\n  \"message\": \"Protocolo criado com sucesso. Prazo estimado: 5 dias uteis.\",\n  \"backend_status\": \"{{ $json.statusCode || 'pending' }}\",\n  \"sender\": \"{{ $json.sender }}\",\n  \"tipo_ato\": \"{{ $json.tipo_ato }}\",\n  \"scrubbed\": \"{{ $json.scrubbed }}\",\n  \"consentimento_lgpd\": {{ $json.consentimento_lgpd || false }},\n  \"note\": \"Backend /protocolo retornou 404 — endpoint ainda nao implementado (Sprint 3). Workflow gerou numero provisional.\"\n}"
      },
      "id": "respond-created",
      "name": "Respond Created",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        1140,
        200
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"status\": \"LGPD_BLOCKED\",\n  \"response\": \"Para criar um protocolo, precisamos do seu consentimento explicito (LGPD art. 7, I). Por favor, responda 'ACEITO' para autorizar o tratamento dos seus dados para fins cartorarios.\",\n  \"action_required\": \"consentimento_lgpd = true\",\n  \"sender\": \"{{ $json.sender }}\"\n}"
      },
      "id": "respond-lgpd-blocked",
      "name": "Respond LGPD_BLOCKED",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        900,
        420
      ]
    }
  ],
