{
  "name": "28 - Audit Snapshot (diario 04:00 S3)",
  "description": "Cron 04:00 diario chama /api/v1/audit/snapshot que exporta audit_log para S3 backup.",
  "active": true,
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 24
            }
          ],
          "hour": 4
        }
      },
      "id": "cron-daily-04:00",
      "name": "Cron Daily 04:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [
        240,
        300
      ],
      "typeVersion": 1.2
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.2notasudi.com.br/api/v1/audit/snapshot",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-API-Key",
              "value": "={{ $env.CARTORIO_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{}",
        "options": {
          "timeout": 120000
        }
      },
      "id": "post-snapshot-audit",
      "name": "POST Snapshot Audit",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        460,
        300
      ],
      "typeVersion": 4.2,
      "options": {
        "timeout": 5000
      }
    }
  ],
  "connections": {
    "Cron Daily 04:00": {
      "main": [
        [
          {
            "node": "POST Snapshot Audit",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "callerPolicy": "workflowsFromSameOwner"
  },
  "tags": [
    {
      "name": "cartorio"
    },
    {
      "name": "audit"
    },
    {
      "name": "snapshot"
    },
    {
      "name": "cron"
    }
  ]
}