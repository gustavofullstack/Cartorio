# cartorio-backup-status - cron hourly E6.S7.T10
# Monitora /api/v1/health/backup e alerta via Telegram quando ok=false.
#
# Setup:
#   sudo cp infra/cron/cartorio-backup-status /etc/cron.d/
#   sudo systemctl restart cron
#   sudo chmod 644 /etc/cron.d/cartorio-backup-status
#
# Env vars devem estar em /etc/cartorio-backup/cartorio-backup-status.env
#   CARTORIO_API_KEY=<api-key>
#   CARTORIO_API_URL=https://api.2notasudi.com.br
#   TELEGRAM_BOT_TOKEN=<bot-token>
#   TELEGRAM_CHAT_ID=<chat-id>
#
# Horario: hourly (XX:00) - testa em horarios diferentes para nao coincidir
# com cartorio-backup.sh (03:00 diario).

0 * * * * root /usr/bin/env bash -c "set -a; source /etc/cartorio-backup/cartorio-backup-status.env; set +a; exec /usr/local/bin/cartorio-backup-status.sh" >> /var/log/cartorio-backup-status.log 2>&1
