> """Helpers de extracao de contexto de auditoria a partir do FastAPI Request.
  
> Centraliza a leitura de `request.state` (populado por RequestContextMiddleware)
> para que rotas nao precisem repetir `getattr(request.state, "X", None)` 5 vezes.
  
> Por que isso existe:
> - LGPD art. 37: registro de operacoes de tratamento precisa de IP/UA/canal.
> - Antes do helper, 1/6 chamadas AuditService.log() propagava o contexto
>   do request. Apos o helper, 6/6 propagam sem duplicacao.
> - NUNCA levanta excecao: se o middleware nao estiver registrado, retorna
>   None para todos os campos. Audit log eh best-effort; nao pode quebrar
>   o request.
> """
> from __future__ import annotations
  
> from fastapi import Request
  
  
> def extract_audit_context(request: Request | None) -> dict[str, str | None]:
>     """Extrai request_id, ip, user_agent, canal do request.state.
  
>     Args:
>         request: FastAPI Request injetado na rota, ou None se nao disponivel
>             (ex: testes, jobs em background).
  
>     Returns:
>         Dict com chaves: request_id, ip, user_agent, canal.
>         Valores sao None se ausentes. NUNCA levanta excecao.
>     """
!     if request is None:
!         return {"request_id": None, "ip": None, "user_agent": None, "canal": None}
  
!     return {
!         "request_id": getattr(request.state, "request_id", None),
!         "ip": getattr(request.state, "client_ip", None),
!         "user_agent": getattr(request.state, "user_agent", None),
!         "canal": getattr(request.state, "canal", None),
!     }
  
  
> def audit_kwargs(request: Request | None) -> dict[str, str | None]:
>     """Retorna dict pronto pra **unpack em AuditService.log().
  
>     Uso:
>         AuditService.log(db, actor_id=..., action=..., resource=...,
>                          payload=..., **audit_kwargs(request))
>     """
!     ctx = extract_audit_context(request)
!     return {
!         "request_id": ctx["request_id"],
!         "ip": ctx["ip"],
!         "user_agent": ctx["user_agent"],
!         "canal": ctx["canal"],
!     }
  
  
> __all__ = ["extract_audit_context", "audit_kwargs"]
