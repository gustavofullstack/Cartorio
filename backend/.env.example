# ============================================================================
# CARTORIO BACKEND - env vars de PRODUCAO (v0.6.0 - validado 2026-06-23)
# ============================================================================
#
# ESTE ARQUIVO NAO DEVE SER COMMITADO COM VALORES REAIS.
# O .env real fica em /etc/easypanel/projects/cartorio/api/code/.env na VPS.
#
# COMO ATUALIZAR:
#   1. Edite o .env localmente com os valores de /Users/gustavoalmeida/.mavis/secrets/cartorio.env
#   2. Copie para VPS: scp .env root@187.77.236.77:/etc/easypanel/projects/cartorio/api/code/.env
#   3. Restart: docker service update --force cartorio_api
#
# Onde guardar as chaves: ~/.mavis/secrets/cartorio.env (chmod 600)
#
# === ESTADO VALIDADO VIA CURL EM 2026-06-23 14:14 BRT ===
# - api.2notasudi.com.br/health -> 200
# - api.2notasudi.com.br/docs -> 200 (Swagger OK)
# - api.2notasudi.com.br/api/v1/health/radar -> 200
# - flow.2notasudi.com.br -> 200 (N8N)
# - whatsapp.2notasudi.com.br -> 200 (Evolution)
# - agent.2notasudi.com.br -> 200 (OpenClaw)
# - easypanel.2notasudi.com.br -> 200
# - supbase.2notasudi.com.br/auth/v1/health -> 401 (Kong OK)
# - chatwoot.2notasudi.com.br -> 000 (DNS pendente)
#
# === DECISÃO ARQUITETURAL 2026-06-23 ===
# - cartorio-api (Python): USA SUPABASE como DB principal
# - N8N/Evolution/Chatwoot/OpenClaw: MANTÊM seus próprios bancos
#   (schemas proprietários — centralizar quebra funcionalidade)
# - Redis: cartorio_redis (cache de sessões + acelerador)
#
# Plano: docs/SUPER_PLANO_v0.6.0.md | Runbook: docs/RUNBOOK_VPS.md
# ============================================================================

# ----------------------------- Aplicacao -----------------------------
APP_ENV=production
APP_NAME=cartorio-backend
APP_PORT=8000
LOG_LEVEL=INFO
APP_VERSION=0.6.0

# ----------------------------- Database (Supabase - PRINCIPAL) -----------------------------
# Conecta via hostname compose 'db' na rede cartorio_supabase_default.
# senha = POSTGRES_PASSWORD do .env do supabase.
# IMPORTANTE: monitor em /usr/local/bin/cartorio-network-monitor.sh
# mantem os containers do Swarm (evolution-api, n8n) na rede compose.
#
# ==============================================================================
# ⚠️  SINCRONIZACAO OBRIGATORIA COM /etc/easypanel/projects/cartorio/supabase/.env
# ==============================================================================
# O SCRAM hash do role supabase_admin no cluster db-1 eh gerado UMA vez durante
# initdb (primeira execucao). Apos isso, o hash vive no volume
# cartorio_supabase_db-data e NAO eh regenerado em restart.
#
# Se voce mudar o POSTGRES_PASSWORD no env do servico db-1 SEM rodar
# ALTER USER dentro do cluster, o SCRAM hash em pg_authid NAO muda e
# todas as conexoes novas vao falhar (veja INCIDENT 2026-06-23 + ADR-013).
#
# REGRA: <COLE_POSTGRES_PASSWORD> neste .env DEVE ser IDENTICO ao
# POSTGRES_PASSWORD em /etc/easypanel/projects/cartorio/supabase/.env.
#
# Para validar: docker exec cartorio_supabase-db-1 psql -U supabase_admin -c "SELECT 1"
# Para corrigir (sem dropar dados): ver infra/supabase/scripts/fix-admin-password.sh
# ==============================================================================
DATABASE_URL=postgresql+psycopg://supabase_admin:<COLE_POSTGRES_PASSWORD>@db:5432/cartorio?sslmode=disable
# ==== A15: Connection pool tuning (Squad A - API/DB Hardening) ====
# Carga esperada: chatbot WhatsApp (Evolution) + N8N workflows (audit/verify/
# metrics) + admin React + openclaw MCP server + Chatwoot handoff = ate 6
# fontes simultaneas. Pico em horario comercial 09:00-17:00 BRT.
# - pool_size=20: 20 conexoes persistentes no pool base
# - max_overflow=10: ate +10 extras sob pico (cap total = 30)
# - pool_recycle=3600: recicla a cada 1h (evita stale em pgBouncer/Traefik)
# - pool_timeout=30: 30s na fila ate TimeoutError se saturar
# - pool_pre_ping=true: testa SELECT 1 antes de cada checkout (custo ~1ms)
# Prometheus gauge: cartorio_db_pool_checked_out (via /api/v1/metrics/prometheus)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=30
DB_POOL_PRE_PING=true
DB_ECHO=false

# ----------------------------- Redis (cartorio_redis) -----------------------------
# Sessões de cliente WhatsApp + cache de workflows + rate limit
# Porta 6379 interna, 1001 no host (DOCKER-USER drop bloqueia acesso externo).
# senha = @Techno832466 (URL encoded %40Techno832466).
REDIS_URL=redis://default:%40Techno832466@cartorio_redis:6379/0
REDIS_SESSION_TTL_SECONDS=86400
REDIS_KEY_PREFIX=cartorio:

# ----------------------------- Audit log -----------------------------
# Chave HMAC (gere com: openssl rand -hex 32)
AUDIT_HMAC_KEY=<COLE_HMAC_HEX_64_CHARS>
AUDIT_VERIFY_CRON=0 3 * * *
AUDIT_CHAIN_VERIFY_ON_BOOT=true

# Dead man's switch (A13): alerta Telegram se audit_log ficar stale
# AUDIT_DEAD_MANS_SWITCH_MINUTES = janela maxima sem mutacoes (default 60min)
# AUDIT_DEAD_MANS_SWITCH_INTERVAL_MINUTES = freq do scheduler in-process (default 15min)
# AUDIT_ALERT_TELEGRAM_CHAT_ID = chat_id Telegram GRUPO PIETRA SQUAD (vazio = so log)
AUDIT_DEAD_MANS_SWITCH_MINUTES=60
AUDIT_DEAD_MANS_SWITCH_INTERVAL_MINUTES=15
AUDIT_ALERT_TELEGRAM_CHAT_ID=

# ----------------------------- PII scrubbing -----------------------------
PII_SCRUB_ENABLED=true
PII_BLOCK_ON_DETECT=true
PII_PATTERNS=cpf,rg,email,phone,credit_card,cep

# ----------------------------- LLM providers -----------------------------
# Opencode-Go (DeepSeek-v4 flash) - LOW COST primario
# Gustavo autorizou em 2026-06-23 13:17 BRT
# Key NUNCA ecoada em chat/logs (regra L3 MEMORY)
OPENCODE_GO_API_KEY=<COLE_OPENCODE_GO_KEY>
OPENCODE_GO_BASE_URL=https://api.opencode.ai/zen/go/v1
OPENCODE_GO_MODEL=deepseek-v4-flash
# Rate limit por sessao (None = desabilitado). Recomendado: 60 em prod.
OPENCODE_GO_RATE_LIMIT_PER_MINUTE=60
OPENCODE_GO_TIMEOUT_SECONDS=30
OPENCODE_GO_MAX_RETRIES=3
# Thinking mode (T57 E08) — controla campo `thinking` no payload Chat Completions.
# Valores:
#   disabled = nao envia `thinking` no payload (default, sem reasoning)
#   enabled  = envia `thinking={"type": "enabled"}` (force on, mais lento + tokens)
#   adaptive = envia `thinking={"type": "adaptive"}` (provider decide quando usar)
# DeepSeek-v4-flash e MiniMax-M3 suportam "adaptive" com 1M context.
OPENCODE_GO_THINKING_MODE=adaptive
# Backward compat (boolean): true equivale a "enabled". Preferir OPENCODE_GO_THINKING_MODE.
OPENCODE_GO_THINKING_ENABLED=true

# OpenClaw gateway (secundario, fallback Anthropic/OpenAI)
# Requer L4 (OPENAI_API_KEY) que depende de L1 (DPA assinado) - LGPD
OPENCLAW_BASE_URL=http://cartorio_openclaw-gateway:18790
OPENCLAW_API_KEY=<COLE_OPENCLAW_GATEWAY_TOKEN>
OPENCLAW_MODEL_PRIMARY=gpt-5.5
OPENCLAW_MODEL_FALLBACK=anthropic/claude-sonnet-4.6
# Thinking mode (deepseek-v4-flash no OpenClaw)
OPENCLAW_THINKING_ENABLED=true
OPENCLAW_ENABLED=false  # true só após L1 DPA assinado

# Provider default (opencode_go | openclaw)
LLM_DEFAULT_PROVIDER=opencode_go
LLM_FALLBACK_CHAIN=opencode_go,openclaw,cache
# Thinking mode global (T57 E08) — default se provider-specific nao setar.
# "adaptive" deixa o provider decidir quando usar thinking (recomendado p/ 1M ctx).
LLM_THINKING_MODE=adaptive

# ----------------------------- Evolution API (WhatsApp) -----------------------------
# https://whatsapp.2notasudi.com.br/manager
# Container: cartorio_evolution-api (UP, sem healthcheck ainda - T0.4)
EVOLUTION_BASE_URL=http://cartorio_evolution-api:8080
EVOLUTION_PUBLIC_URL=https://whatsapp.2notasudi.com.br
EVOLUTION_API_KEY=<COLE_EVOLUTION_API_KEY>
EVOLUTION_INSTANCE=cartorio-2notas
EVOLUTION_WEBHOOK_URL=https://api.2notasudi.com.br/api/v1/webhook/evolution

# ----------------------------- Chatwoot (CRM) -----------------------------
# https://chatwoot.2notasudi.com.br (DNS pendente - T0.9 Pietra UI)
CHATWOOT_BASE_URL=http://cartorio_chatwoot:3000
CHATWOOT_PUBLIC_URL=https://chatwoot.2notasudi.com.br
CHATWOOT_API_KEY=<COLE_CHATWOOT_API_KEY>
CHATWOOT_ACCOUNT_ID=<COLE_ACCOUNT_ID>
CHATWOOT_INBOX_ID=<COLE_INBOX_ID>
CHATWOOT_BOT_TOKEN=<PENDING_GUSTAVO_UI>  # T0.10 Pietra UI

# ----------------------------- n8n (workflows) -----------------------------
# https://flow.2notasudi.com.br
# MCP server: https://cartorio-n8n.dfgdxq.easypanel.host/mcp-server/http
N8N_BASE_URL=http://cartorio_n8n:5678
N8N_PUBLIC_URL=https://flow.2notasudi.com.br
N8N_MCP_URL=https://cartorio-n8n.dfgdxq.easypanel.host/mcp-server/http
N8N_API_KEY=<COLE_N8N_API_KEY>
N8N_WEBHOOK_SECRET=<COLE_N8N_WEBHOOK_SECRET>
N8N_LICENSE_FEAT_VARIABLES=false  # confirmado: feat:variables NÃO licenciado (MEMORY 2026-06-23)

# Healthcheck URLs (T0.4 - adicionar healthcheck nos 3 containers sem check)
N8N_HEALTH_URL=http://cartorio_n8n:5678/healthz
EVOLUTION_HEALTH_URL=http://cartorio_evolution-api:8080/
REDIS_HEALTH_URL=redis://cartorio_redis:6379
OPENCLAW_HEALTH_URL=http://cartorio_openclaw-gateway:18790/health
CHATWOOT_HEALTH_URL=http://cartorio_chatwoot:3000/api
SUPABASE_HEALTH_URL=https://supbase.2notasudi.com.br/auth/v1/health
CARTORIO_API_HEALTH_URL=http://cartorio_api:8000/health

# ----------------------------- Auth inter-service -----------------------------
# Chave compartilhada N8N <-> API (header X-API-Key).
# N8N envia em chamadas de audit/verify. API valida antes de processar.
# Gerada via: openssl rand -hex 32 (64 chars hex). Rotacionar a cada 90 dias.
# Setar no N8N: docker service update --env-add CARTORIO_API_KEY=<valor> cartorio_n8n
# Setar na API: docker service update --env-add CARTORIO_API_KEY=<valor> cartorio_api
CARTORIO_API_KEY=<COLE_HEX_64>

# ----------------------------- Supabase (acesso direto) -----------------------------
# DNS typo 'supbase' (mantido por compatibilidade - decisão T0.12 pendente)
SUPABASE_URL=https://supbase.2notasudi.com.br
SUPABASE_ANON_KEY=<COLE_SUPABASE_ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<COLE_SUPABASE_SERVICE_ROLE_KEY>
SUPABASE_DB_HOST=<COLE_SUPABASE_DB_HOST>  # ex: 10.0.1.34 (IP direto Swarm)
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=cartorio
SUPABASE_DB_USER=supabase_admin
SUPABASE_DB_PASSWORD=<COLE_SUPABASE_DB_PASSWORD>

# ----------------------------- Tailscale (subdomínio OpenClaw) -----------------------------
# T0.7 cartorio-devops: cert wildcard + Traefik router *.tail2fe279.ts.net
TAILSCALE_HOSTNAME=vps-cartorio
TAILSCALE_TAILNET=tail2fe279.ts.net
OPENCLAW_TAILSCALE_URL=https://vps-cartorio.tail2fe279.ts.net:18790

# ----------------------------- LGPD -----------------------------
DPO_EMAIL=dpo@2notasudi.com.br
RETENTION_DAYS_CONVERSAS=365
RETENTION_DAYS_AUDIT=1825
LGPD_DPA_MINIMAX_SIGNED=false  # L1 pendente (2-4 semanas jurídicas)
LGPD_STAGING_ONLY=true  # até L1 assinado, ambiente é STAGING ONLY

# ----------------------------- CORS -----------------------------
CORS_ORIGINS=["http://localhost:3000","https://admin.2notasudi.com.br","https://app.2notasudi.com.br","https://flow.2notasudi.com.br","https://agent.2notasudi.com.br","https://chatwoot.2notasudi.com.br"]

# ----------------------------- MCP server (expõe tools MCP) -----------------------------
MCP_SERVER_ENABLED=true
MCP_SERVER_TRANSPORT=http
MCP_SERVER_PORT=8100
MCP_API_KEY=<COLE_MCP_API_KEY_32_CHARS>
MCP_TOOLS_LIST=consultar_emolumento,criar_protocolo,consultar_protocolo,agendar_atendimento,transferir_humano,buscar_cep,validar_cpf

# ----------------------------- Easypanel -----------------------------
# T0.11 Pietra UI: regenerar key (a antiga morreu 401)
EASYPANEL_URL=https://easypanel.2notasudi.com.br
EASYPANEL_API_KEY=<COLE_EASYPANEL_API_KEY>
EASYPANEL_PROJECT=cartorio

# ----------------------------- VPS / SSH -----------------------------
# SEMPRE use ssh cartorio (alias correto). NUNCA ssh vps (IP stale).
# Tailscale IP: 100.99.172.84 (vps-cartorio)
# Public IP: 187.77.236.77
VPS_TAILSCALE_IP=100.99.172.84
VPS_PUBLIC_IP=187.77.236.77
VPS_SSH_KEY=~/.ssh/id_ed25519_cartorio
VPS_SSH_ALIAS=cartorio

# ----------------------------- Telemetry -----------------------------
# Sprint 2 (T2.12) - dashboard custo OpenCode-Go
TELEMETRY_ENABLED=true
TELEMETRY_OPENCODE_DAILY_LIMIT_USD=5.0

# ----------------------------- Backup DB 4x/dia (A14) -----------------------------
# pg_basebackup 4x/dia UTC (cron 0 */6 em /etc/cron.d/cartorio-pgbase).
# Script: /usr/local/bin/pg_basebackup_4x.sh
# Log: /var/log/cartorio-pgbase.log
# Endpoint health: GET /api/v1/health/backup-v2 (200 healthy / 503 stale|critical|empty)
#
# ⚠️ S3 MENSAL = EXPLICIT PLACEHOLDER (NAO IMPLEMENTADO)
# Para ativar upload mensal (1o dia do mes) ao S3, Gustavo precisa:
#   1. Criar bucket S3 (ex: s3://cartorio-backups-prod/pgbase/)
#   2. Criar IAM user com policy minima de write nesse bucket
#   3. Exportar as 3 vars abaixo no env do cron (/etc/cron.d/cartorio-pgbase)
#      OU criar /root/.aws/credentials
#   4. Instalar aws-cli no VPS: apt install awscli
# Ate la, script loga "SKIPPED (credenciais AWS nao configuradas)" todo dia 1o.
# Backup LOCAL (7d) NAO eh afetado — segue 4x/dia normalmente.
#AWS_ACCESS_KEY_ID=<PENDING_GUSTAVO_AWS_ACCESS_KEY_ID>
#AWS_SECRET_ACCESS_KEY=<PENDING_GUSTAVO_AWS_SECRET_ACCESS_KEY>
#AWS_S3_BUCKET=<PENDING_GUSTAVO_S3_BUCKET_NAME>
#AWS_REGION=sa-east-1
