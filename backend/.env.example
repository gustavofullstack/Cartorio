# ============================================
# CARTORIO BACKEND - env vars (SEM senhas reais)
# ============================================
# Copie pra .env e preencha com valores reais.
# .env esta no .gitignore. NUNCA commitar credenciais.

# --- Aplicacao ---
APP_ENV=production
APP_NAME=cartorio-backend
APP_PORT=8000
LOG_LEVEL=INFO

# --- Database (Supabase-db em compose network cartorio_supabase_default) ---
# host: 'db' (hostname compose) OU 'cartorio_supabase-db-1' (container name) OU IP 172.16.2.x
# user: supabase_admin (NAO postgres)
# IMPORTANTE: monitor em /usr/local/bin/cartorio-network-monitor.sh mantem
# os containers do Swarm (evolution-api, n8n) na rede compose. Sem monitor,
# Swarm restart remove a network e quebra a conexao.
DATABASE_URL=postgresql+psycopg://supabase_admin:your-super-secret-and-long-postgres-password@db:5432/cartorio?sslmode=disable

# --- Redis (cartorio_redis centralizado na porta 6379) ---
# user: default
# senha: @Techno832466 (encode %40Techno832466 na URL)
REDIS_URL=redis://default:%40Techno832466@cartorio_redis:6379/0

# --- Audit log ---
# Chave HMAC pra assinar entradas do audit log (gere com: openssl rand -hex 32)
AUDIT_HMAC_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# --- PII scrubbing ---
PII_SCRUB_ENABLED=true

# --- LLM (LiteLLM gateway) ---
LITELLM_BASE_URL=http://cartorio_litellm:4000
LITELLM_API_KEY=CHANGE_ME
LITELLM_MODEL_PRIMARY=claude-opus-4-5
LITELLM_MODEL_FALLBACK=gpt-5.5

# --- Evolution API (WhatsApp) ---
EVOLUTION_BASE_URL=http://cartorio_evolution-api:8080
EVOLUTION_API_KEY=CHANGE_ME
EVOLUTION_INSTANCE=cartorio-2notas

# --- OpenClaw gateway (porta real = 18790, nao 18789) ---
OPENCLAW_BASE_URL=http://cartorio_openclaw-gateway:18790
OPENCLAW_API_KEY=CHANGE_ME

# --- n8n (workflow) ---
N8N_BASE_URL=http://cartorio_n8n:5678
N8N_WEBHOOK_SECRET=CHANGE_ME

# --- LGPD ---
DPO_EMAIL=dpo@cartorio.local
RETENTION_DAYS_CONVERSAS=365
RETENTION_DAYS_AUDIT=1825  # 5 anos, exigencia legal
