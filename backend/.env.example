# ============================================================================
# CARTORIO BACKEND - env vars de PRODUCAO
# ============================================================================
#
# ESTE ARQUIVO NAO DEVE SER COMMITADO COM VALORES REAIS.
# O .env real fica em /etc/easypanel/projects/cartorio/api/code/.env na VPS.
#
# COMO ATUALIZAR:
#   1. Edite o .env localmente com os valores de /Users/gustavoalmeida/.mavis/secrets/cartorio.env
#   2. Copie para VPS: scp .env root@187.77.236.77:/etc/easypanel/projects/cartorio/api/code/.env
#   3. Restart: docker service update --force cartorio_api
#
# Onde guardar as chaves: ~/.mavis/secrets/cartorio.env (chmod 600)
# ============================================================================

# ----------------------------- Aplicacao -----------------------------
APP_ENV=production
APP_NAME=cartorio-backend
APP_PORT=8000
LOG_LEVEL=INFO

# ----------------------------- Database (Supabase) -----------------------------
# Conecta via hostname compose 'db' na rede cartorio_supabase_default.
# senha = POSTGRES_PASSWORD do .env do supabase.
# IMPORTANTE: monitor em /usr/local/bin/cartorio-network-monitor.sh
# mantem os containers do Swarm (evolution-api, n8n) na rede compose.
DATABASE_URL=postgresql+psycopg://supabase_admin:<COLE_POSTGRES_PASSWORD>@db:5432/cartorio?sslmode=disable
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5

# ----------------------------- Redis (cartorio_redis) -----------------------------
# Porta 6379 interna, 1001 no host (DOCKER-USER drop bloqueia acesso externo).
# senha = @Techno832466 (URL encoded %40Techno832466).
REDIS_URL=redis://default:%40Techno832466@cartorio_redis:6379/0
REDIS_SESSION_TTL_SECONDS=86400

# ----------------------------- Audit log -----------------------------
# Chave HMAC (gere com: openssl rand -hex 32)
AUDIT_HMAC_KEY=<COLE_HMAC_HEX_64_CHARS>
AUDIT_VERIFY_CRON=0 3 * * *

# ----------------------------- PII scrubbing -----------------------------
PII_SCRUB_ENABLED=true
PII_BLOCK_ON_DETECT=true

# ----------------------------- LLM providers -----------------------------
# Opencode-Go (DeepSeek-v4 flash) - LOW COST primario
OPENCODE_GO_API_KEY=<COLE_OPENCODE_GO_KEY>
OPENCODE_GO_BASE_URL=https://api.opencode.ai/v1
OPENCODE_GO_MODEL=deepseek-v4-flash

# OpenClaw gateway (secundario, fallback Anthropic/OpenAI)
OPENCLAW_BASE_URL=http://cartorio_openclaw-gateway:18790
OPENCLAW_API_KEY=<COLE_OPENCLAW_GATEWAY_TOKEN>
OPENCLAW_MODEL_PRIMARY=gpt-5.5
OPENCLAW_MODEL_FALLBACK=anthropic/claude-sonnet-4.6

# Provider default (opencode_go | openclaw)
LLM_DEFAULT_PROVIDER=opencode_go

# ----------------------------- Evolution API (WhatsApp) -----------------------------
# https://whatsapp.2notasudi.com.br/manager
EVOLUTION_BASE_URL=http://cartorio_evolution-api:8080
EVOLUTION_API_KEY=<COLE_EVOLUTION_API_KEY>
EVOLUTION_INSTANCE=cartorio-2notas

# ----------------------------- Chatwoot (CRM) -----------------------------
# https://chatwoot.2notasudi.com.br (subir como novo servico se quiser)
CHATWOOT_BASE_URL=http://cartorio_chatwoot:3000
CHATWOOT_API_KEY=<COLE_CHATWOOT_API_KEY>
CHATWOOT_ACCOUNT_ID=<COLE_ACCOUNT_ID>
CHATWOOT_INBOX_ID=<COLE_INBOX_ID>

# ----------------------------- n8n (workflows) -----------------------------
N8N_BASE_URL=http://cartorio_n8n:5678
N8N_API_KEY=<COLE_N8N_API_KEY>
N8N_MCP_URL=https://cartorio-n8n.dfgdxq.easypanel.host/mcp-server/http
N8N_WEBHOOK_SECRET=<COLE_N8N_WEBHOOK_SECRET>

# ----------------------------- Auth inter-service -----------------------------
# Chave compartilhada N8N <-> API (header X-API-Key).
# N8N envia em chamadas de audit/verify. API valida antes de processar.
# Gerada via: openssl rand -hex 32 (64 chars hex). Rotacionar a cada 90 dias.
# Setar no N8N: docker service update --env-add CARTORIO_API_KEY=<valor> cartorio_n8n
# Setar na API: docker service update --env-add CARTORIO_API_KEY=<valor> cartorio_api
CARTORIO_API_KEY=<COLE_HEX_64>

# Token do Chatwoot Agent Bot (WF3 - Handoff Humano).
# Workflows 08/09 usam $env.CHATWOOT_BOT_TOKEN. PENDENTE ate Gustavo criar
# Agent Bot em https://cartorio-chatwoot.dfgdxq.easypanel.host/super_admin/agent_bots
CHATWOOT_BOT_TOKEN=<PENDING_GUSTAVO_UI>

# ----------------------------- Supabase (acesso direto) -----------------------------
# DNS typo 'supbase' (mantido por compatibilidade)
SUPABASE_URL=https://supbase.2notasudi.com.br
SUPABASE_ANON_KEY=<COLE_SUPABASE_ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<COLE_SUPABASE_SERVICE_ROLE_KEY>

# ----------------------------- LGPD -----------------------------
DPO_EMAIL=dpo@2notasudi.com.br
RETENTION_DAYS_CONVERSAS=365
RETENTION_DAYS_AUDIT=1825

# ----------------------------- CORS -----------------------------
CORS_ORIGINS=["http://localhost:3000","https://admin.2notasudi.com.br","https://app.2notasudi.com.br"]

# ----------------------------- MCP server (expõe tools MCP) -----------------------------
MCP_SERVER_ENABLED=true
MCP_SERVER_TRANSPORT=http
MCP_SERVER_PORT=8100
MCP_API_KEY=<COLE_MCP_API_KEY_32_CHARS>